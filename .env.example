# ai-hub (旧 ai-watch) 用環境変数テンプレート。このファイルをコピーして .env として使う。
# cp .env.example .env

# Claude API (要約生成用)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Supabase (ai_watch.articles 差分保存先)
# SERVICE_ROLE キーは https://supabase.com/dashboard/project/zrawhzwtppmlxyhngnju/settings/api-keys
# の「service_role」(secret) をコピーして貼り付ける
SUPABASE_URL=https://zrawhzwtppmlxyhngnju.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Shopify Admin API (admin/server.py の /admin Shopify タブで使用)
# 取得手順: Shopify管理画面 → 設定 → アプリと販売チャネル → アプリ開発
#  → カスタムアプリ作成 → Admin APIアクセストークン
# 必要スコープ: read_products, read_orders, read_inventory, read_customers
# (在庫更新もしたい場合は write_inventory / write_products も追加)
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_STORE_DOMAIN=84c617.myshopify.com
# SHOPIFY_API_VERSION=2024-10
